{
  "name": "all-camere-world",
  "version": "1.0.0",
  "description": "This is All Camere World project backend",
  "main": "src/server.ts",
  "scripts": {
    "start": "NODE_OPTIONS=--max-http-header-size=65536 ts-node src/server.ts",
    "dev": "NODE_OPTIONS=--max-http-header-size=65536 nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start:dev": "NODE_OPTIONS=--max-http-header-size=65536 nodemon --exec ts-node src/server.ts",
    "train": "nodemon --exec ts-node src/train.ts",
    "seed:products": "ts-node src/scripts/seed-products.ts",
    "migrate:member-roles": "ts-node src/scripts/migrate-member-role.ts",
    "migrate:product-status": "ts-node src/scripts/migrate-product-status.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "Jon",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "connect-mongodb-session": "^3.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "ejs": "^3.1.6",
    "express": "^4.17.3",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.30.1",
    "mongodb": "^3.2.6",
    "mongoose": "^6.2.9",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.3",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/connect-mongodb-session": "^2.4.8",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.3",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/socket.io": "^3.0.2",
    "@types/uuid": "^10.0.0",
    "chalk": "^4.1.2",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  }
