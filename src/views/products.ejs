<%- include('includes/header') %>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap");

  body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(135deg, #050509, #0b0d13, #141621);
    font-family: "Montserrat", Arial, sans-serif;
    color: #f5f5f5;
    padding: 24px 16px 32px;
  }

  .nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
    background: #05070c;
    padding: 12px 16px;
    border-radius: 12px;
    border: 1px solid #262a34;
  }

  .nav-links {
    display: flex;
    gap: 12px;
  }

  .nav-links a {
    padding: 10px 14px;
    border-radius: 12px;
    color: #f5f5f5;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    background: rgba(255, 85, 51, 0.1);
    border-color: rgba(255, 85, 51, 0.5);
    color: #ff5533;
  }

  .page-title {
    font-size: 22px;
    color: #e6e6e6;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .card {
    width: 100%;
    background: #101218;
    border-radius: 10px;
    padding: 24px 24px 26px;
    box-shadow: 0 0 50px rgba(0, 0, 0, 0.6),
      inset 0 0 20px rgba(255, 70, 50, 0.15);
    backdrop-filter: blur(10px);
    border: 1px solid #262a34;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .section-title {
    font-size: 16px;
    letter-spacing: 1px;
    color: #f5f5f5;
    font-weight: 700;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    color: #f5f5f5;
    font-size: 14px;
  }

  thead tr {
    background: #181b22;
  }

  thead th {
    padding: 12px 10px;
    font-weight: 700;
    border-bottom: 1px solid #262a34;
    letter-spacing: 0.3px;
  }

  tbody tr {
    background: #101218;
  }

  tbody td {
    padding: 10px;
    border-bottom: 1px solid #262a34;
  }

  tbody tr:hover {
    background: #171a23;
  }

  select.new-product-status {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    color: #f5f5f5;
    border: 1px solid #262a34;
    border-radius: 10px;
    padding: 8px 10px;
    outline: none;
  }

  .primary-btn,
  .secondary-btn {
    padding: 12px 16px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    font-weight: 700;
    transition: 0.25s;
    color: #f5f5f5;
    letter-spacing: 0.4px;
  }

  .primary-btn {
    background: linear-gradient(135deg, #ff5533, #ff8b3d);
  }

  .secondary-btn {
    background: linear-gradient(135deg, #1f8fff, #3bc6ff);
  }

  .primary-btn:hover,
  .secondary-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 18px rgba(0, 0, 0, 0.25);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
  }

  .input-group {
    text-align: left;
  }

  .input-group label {
    display: block;
    font-size: 13px;
    color: #b3b3b3;
    margin-bottom: 6px;
    letter-spacing: 0.5px;
  }

  .input-group input,
  .input-group textarea,
  .input-group select {
    width: 100%;
    padding: 12px 12px;
    border-radius: 10px;
    border: 1px solid #262a34;
    background: rgba(255, 255, 255, 0.04);
    color: #f5f5f5;
    outline: none;
    transition: border 0.2s, box-shadow 0.2s;
  }

  .input-group input:focus,
  .input-group textarea:focus,
  .input-group select:focus {
    border: 1px solid rgba(59, 198, 255, 0.5);
    box-shadow: 0 0 0 3px rgba(59, 198, 255, 0.2);
  }

  textarea.product-desc {
    min-height: 90px;
  }

  .img-frame {
    margin-top: 12px;
  }

  .media-frame {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 14px;
  }

  .upload-img-box {
    position: relative;
    border: 1px dashed #262a34;
    border-radius: 12px;
    padding: 14px;
    text-align: center;
    background: rgba(255, 255, 255, 0.03);
  }

  .upload-img-box img {
    width: 100%;
    max-width: 120px;
    height: 120px;
    object-fit: contain;
    margin: 0 auto 10px;
    display: block;
  }

  .upload-img-box input[type="file"] {
    width: 100%;
    color: #9fa3aa;
  }

  .operation-buttons {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 10px;
  }

  .dish-container {
    display: none;
    margin-top: 10px;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  @media (max-width: 768px) {
    body {
      padding: 16px 12px 24px;
    }
    table {
      font-size: 13px;
    }
    .nav-bar {
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
    }
  }
</style>

<body>
  <div class="nav-bar">
    <div class="page-title">Camera Inventory</div>
    <div class="nav-links">
      <a href="/admin/">Home</a>
      <a href="/admin/product/all" class="active">Cameras</a>
      <a href="/admin/user/all">Users</a>
      <a href="/admin/logout" onclick="return confirm('Do you want to logout?')"
        >Logout</a
      >
    </div>
  </div>

  <div class="cards products-container">
    <div class="card">
      <div class="section-header">
        <div class="section-title">Current Camera Stock</div>
        <button class="secondary-btn" id="process-btn">New Camera</button>
      </div>
      <div class="table-wrapper">
        <table class="table table-hover">
          <thead>
            <tr>
              <th scope="col">#</th>
              <th scope="col">Camera Model</th>
              <th scope="col">Brand</th>
              <th scope="col">Sensor</th>
              <th scope="col">Price ($)</th>
              <th scope="col">Stock</th>
              <th scope="col">Status</th>
              <th scope="col">Action</th>
            </tr>
          </thead>
          <!--  LOOP PRODUCTS: START  -->
          <% products.map(function (value, key) { %>
          <tbody>
            <td><%= key +1 %></td>
            <td><%= value.cameraModel %></td>
            <td><%= value.brand %></td>
            <td><%= value.sensorType || '' %></td>
            <td><%= value.price %></td>
            <td><%= value.stock %></td>
            <td>
              <select class="spec-select new-product-status" id="<%= value._id%>">
                <option value="NEW" <%= value.productStatus === "NEW" || value.productStatus === "PAUSE" ? 'selected' : '' %>>NEW</option>
                <option value="USED" <%= value.productStatus === "USED" || value.productStatus === "PROCESS" ? 'selected' : '' %>>USED</option>
                <option value="SOLD_OUT" <%= value.productStatus === "SOLD_OUT" ? 'selected' : '' %>>SOLD OUT</option>
                <option value="DELETE" <%= value.productStatus === "DELETE" ? 'selected' : '' %>>DELETE</option>
              </select>
            </td>
            <td>
              <button
                type="button"
                class="primary-btn delete-product"
                data-id="<%= value._id %>"
                style="background:#d9534f;"
              >
                Delete
              </button>
            </td>
          </tbody>
          <% })%>
          <!--  LOOP PRODUCTS: END  -->
        </table>
      </div>
    </div>

    <form
      onsubmit="return validateForm()"
      action="/admin/product/create"
      method="POST"
      class="card dish-container"
      enctype="multipart/form-data"
    >
      <div class="section-header">
        <div class="section-title">New Camera Detail</div>
        <button class="primary-btn" id="cancel-btn" type="button">Close</button>
      </div>

      <div class="form-grid">
        <div class="input-group">
          <label>Camera Model</label>
          <input
            type="text"
            placeholder="e.g. Sony A7 IV"
            name="cameraModel"
            class="product-name"
          />
        </div>
        <input name="productStatus" value="NEW" class="product-status" hidden />
        <div class="input-group">
          <label>Price ($)</label>
          <input
            type="number"
            placeholder="Price"
            name="price"
            class="product-price"
          />
        </div>
        <div class="input-group">
          <label>Stock</label>
          <input
            type="number"
            placeholder="Units in stock"
            name="stock"
            class="product-left-count"
          />
        </div>
        <div class="input-group">
          <label>Brand</label>
          <input type="text" name="brand" placeholder="Sony" />
        </div>

        <div class="input-group">
          <label>Category</label>
          <select name="category">
            <option value="mirrorless" selected>Mirrorless</option>
            <option value="dslr">DSLR</option>
            <option value="cinema">Cinema</option>
            <option value="lens">Lens</option>
            <option value="drone">Drone</option>
            <option value="accessory">Accessory</option>
          </select>
        </div>

        <div class="input-group">
          <label>Sensor Type</label>
          <input type="text" name="sensorType" placeholder="Full-frame / APS-C" />
        </div>

        <div class="input-group">
          <label>Resolution (MP)</label>
          <input type="number" step="0.1" name="resolutionMp" placeholder="50" />
        </div>

        <div class="input-group">
          <label>Mount Type</label>
          <input type="text" name="mountType" placeholder="E-mount" />
        </div>
      </div>

      <div class="input-group">
        <label>Camera Description</label>
        <textarea name="description" class="product-desc"></textarea>
      </div>

      <div class="img-frame">
        <label>Camera Images</label>
        <div class="media-frame">
          <div class="upload-img-box">
            <img src="/img/upload.svg" class="1" id="image-section-1" />
            <input
              type="file"
              id="file"
              name="images"
              class="image-one"
              required
              onchange="previewFileHandler(this, 1)"
            />
          </div>
          <div class="upload-img-box">
            <img src="/img/upload.svg" class="2" id="image-section-2" />
            <input
              type="file"
              id="file"
              name="images"
              class="image-two"
              onchange="previewFileHandler(this, 2)"
            />
          </div>
          <div class="upload-img-box">
            <img src="/img/upload.svg" class="3" id="image-section-3" />
            <input
              type="file"
              id="file"
              name="images"
              class="image-three"
              onchange="previewFileHandler(this, 3)"
            />
          </div>
          <div class="upload-img-box">
            <img src="/img/upload.svg" class="4" id="image-section-4" />
            <input
              type="file"
              id="file"
              name="images"
              class="image-four"
              onchange="previewFileHandler(this, 4)"
            />
          </div>
          <div class="upload-img-box">
            <img src="/img/upload.svg" class="5" id="image-section-5" />
            <input
              type="file"
              id="file"
              name="images"
              class="image-five"
              onchange="previewFileHandler(this, 5)"
            />
          </div>
          <input name="restaurantIid" class="restaurant-id" hidden />
        </div>
      </div>

      <div class="operation-buttons">
        <button class="secondary-btn" id="create-btn" type="submit">Create</button>
      </div>
    </form>
  </div>

  <script type="text/javascript" src="/js/products.js"></script>
</body>

<%- include('includes/footer') %>
