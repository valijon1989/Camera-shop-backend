<%- include('includes/header') %>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap");

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #0d0f14, #1a1c25, #0c0f12);
    font-family: "Montserrat", Arial, sans-serif;
    color: #fff;
    padding: 30px 16px;
  }

  .card {
    width: 100%;
    max-width: 900px;
    padding: 36px 40px 44px;
    background: rgba(15, 17, 22, 0.9);
    border-radius: 22px;
    box-shadow: 0 0 50px rgba(0, 0, 0, 0.6),
      inset 0 0 20px rgba(255, 70, 50, 0.15);
    backdrop-filter: blur(10px);
  }

  h1 {
    margin: 0 0 6px 0;
    font-size: 26px;
    letter-spacing: 2px;
    color: #e6e6e6;
    font-weight: 600;
    text-align: center;
  }

  .sub {
    color: #909090;
    margin-bottom: 26px;
    letter-spacing: 1px;
    text-align: center;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
  }

  .input-group {
    text-align: left;
  }

  .input-group label {
    display: block;
    font-size: 13px;
    color: #b3b3b3;
    margin-bottom: 6px;
    letter-spacing: 0.5px;
  }

  .input-group input,
  .input-group select,
  .input-group textarea {
    width: 100%;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    outline: none;
    transition: border 0.2s, box-shadow 0.2s;
  }

  .input-group input:focus,
  .input-group textarea:focus {
    border: 1px solid rgba(255, 125, 90, 0.5);
    box-shadow: 0 0 0 3px rgba(255, 125, 90, 0.2);
  }

  .upload-area {
    margin-top: 12px;
    padding: 18px;
    border: 1px dashed rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 18px;
    align-items: center;
  }

  .upload-img-frame {
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    transition: border 0.2s;
  }

  .upload-img-frame.success {
    border-color: rgba(59, 198, 255, 0.5);
  }

  .file-box {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .upload-name {
    flex: 1;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: #b3b3b3;
  }

  .file-input-label {
    padding: 12px 16px;
    background: linear-gradient(135deg, #1f8fff, #3bc6ff);
    border-radius: 10px;
    color: #fff;
    cursor: pointer;
    font-weight: 700;
    letter-spacing: 0.5px;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .file-input-label:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(59, 198, 255, 0.35);
  }

  .thumbnail-desc {
    font-size: 12px;
    color: #9fa3aa;
    margin-top: 10px;
    line-height: 1.5;
  }

  .btn {
    display: block;
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #ff4d4d, #ff7a3d);
    border: none;
    border-radius: 12px;
    color: #fff;
    cursor: pointer;
    font-size: 16px;
    margin-top: 18px;
    font-weight: bold;
    transition: 0.25s;
  }

  .btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(255, 100, 80, 0.35);
  }

  .link-row {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: #a5a5a5;
    margin-top: 18px;
  }

  .link-row a {
    color: #3bc6ff;
  }
</style>

<body>
  <div class="card signup-container">
    <h1>Create Account</h1>
    <div class="sub">Camera Shop Admin Signup</div>
    <% if (typeof message !== "undefined" && message) { %>
      <div style="margin-bottom:12px;padding:10px;border-radius:10px;background:rgba(255,77,77,0.12);color:#ffb8b8;font-size:13px;">
        <%= message %>
      </div>
    <% } %>

    <form
      onsubmit="return validateSignupForm()"
      action="/admin/signup"
      method="POST"
      enctype="multipart/form-data"
    >
      <div class="grid">
        <div class="input-group">
          <label>Admin *</label>
          <input
            type="text"
            name="memberNick"
            class="member-nick"
            placeholder="Admin username"
          />
        </div>
        <div class="input-group">
          <label>Phone *</label>
          <input
            type="text"
            name="memberPhone"
            class="member-phone"
            placeholder="Phone"
          />
        </div>
        <div class="input-group">
          <label>Password *</label>
          <input
            type="password"
            name="memberPassword"
            class="member-password"
            placeholder="Password"
          />
        </div>
        <div class="input-group">
          <label>Repeat Password *</label>
          <input
            type="password"
            name="confirmPassword"
            class="confirm-password"
            placeholder="Repeat password"
          />
        </div>
      </div>

      <div class="upload-area">
        <img class="upload-img-frame" src="/img/default.jpeg" />
        <div class="upload-container">
          <span class="media-text">Admin image</span>
          <div class="file-box bs3-primary preview-image">
            <input class="upload-name" value="Choose image" disabled="disabled" />
            <label for="input-file" class="file-input-label">Upload Image</label>
            <input
              type="file"
              id="input-file"
              class="upload-hidden form-control-file member-image"
              name="memberImage"
            />
          </div>
          <p class="thumbnail-desc">
            Please upload restaurant image.<br />
            Only .jpg, .jpeg, or .png formats allowed.
          </p>
        </div>
      </div>

      <input name="memberType" value="ADMIN" hidden />

      <button class="btn signup-btn" name="signup" type="submit">Signup</button>

      <div class="link-row">
        <span>Already registered? <a href="/admin/login">Login</a></span>
        <a href="/admin">Home</a>
      </div>
    </form>
  </div>

  <script type="text/javascript" src="/js/signup.js"></script>
</body>

<%- include('includes/footer') %>
